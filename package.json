{
	"name": "@juicerq/agent-api",
	"version": "0.2.1",
	"description": "CLI para invocar procedures oRPC/tRPC in-process — list, show, call, via agent-api.config.ts",
	"keywords": [
		"agent",
		"bun",
		"cli",
		"dev-tool",
		"orpc",
		"rpc",
		"trpc"
	],
	"homepage": "https://github.com/juicerq/agent-api#readme",
	"bugs": {
		"url": "https://github.com/juicerq/agent-api/issues"
	},
	"license": "MIT",
	"author": "Juicerq",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/juicerq/agent-api.git"
	},
	"bin": {
		"agent-api": "./src/cli.ts"
	},
	"files": [
		"src"
	],
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./orpc": "./src/adapters/orpc.ts",
		"./trpc": "./src/adapters/trpc.ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"typecheck": "tsgo -p tsconfig.json",
		"lint": "oxlint . --no-error-on-unmatched-pattern",
		"format": "oxfmt .",
		"test": "bun test"
	},
	"devDependencies": {
		"@orpc/server": "^1.14.0",
		"@trpc/server": "^11.16.0",
		"@typescript/native-preview": "^7.0.0-dev.20260422.1",
		"bun-types": "^1.3.13",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"@orpc/server": "^1.14.0",
		"@trpc/server": "^11.0.0"
	},
	"peerDependenciesMeta": {
		"@orpc/server": {
			"optional": true
		},
		"@trpc/server": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.3"
	}
}
